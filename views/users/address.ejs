<%- layout("/layouts/boilerplate") %>
<script>
    let mapToken = "<%= process.env.MAP_TOKEN %>"
</script>
<div class="row">
    <div class="col-md-6 offset-3 mt-4">
        <h3>Add Delivery Address</h3>
        <button type="button" id="detectLocation" class="btn btn-outline-primary">
            <i class="fa-solid fa-location-dot"></i> Detect My Location
        </button>

        <div id="locationStatus" style="display:none;">Detecting location...</div>

        <div class="divider mt-4 mb-3">
            <span style="margin-left: 300px">or</span>
            <!-- <hr> -->
          </div>

        <form action="/profile/address" method="post" class="needs-validation" novalidate>
            <div class="mb-3">
                <label class="form-label">Street Address</label>
                <input type="text" id="street" name="street" class="form-control" 
                    value="<%= currUser.address?.street || '' %>" required>
                    <p style="font-size: .79rem;">Please Add <b>Plot</b><span style="color: red;">*</span> Number For Perfect Location!</p>
                <div class="invalid-feedback">Please enter street address</div>
            </div>
            <div class="mb-3">
                <label class="form-label">State</label>
                <input type="text" id="state" name="state" class="form-control"
                    value="<%= currUser.address?.state || '' %>" required>
                <div class="invalid-feedback">Please enter state</div>
            </div>
            <div class="mb-3">
                <label class="form-label">City</label>
                <input type="text" id="city" name="city" class="form-control"
                    value="<%= currUser.address?.city || '' %>" required>
                <div class="invalid-feedback">Please enter city</div>
            </div>
            <div class="mb-3">
                <label class="form-label">Pincode</label>
                <input type="text" id="pincode" name="pincode" class="form-control" 
                    pattern="[0-9]{6}" maxlength="6"
                    value="<%= currUser.address?.pincode || '' %>" required>
                <div class="invalid-feedback">Please enter valid 6-digit pincode</div>
            </div>
            <button type="submit" class="btn btn-success w-70 text-center">
                Save Address & Continue
            </button>
        </form>
    </div>
</div>
<script>
    if(document.getElementById("map")){
        mapboxgl.accessToken = mapToken;
        const map = new mapboxgl.Map({
            container: 'map', // container ID
            center: [75.77694339685273, 26.909805885517095], // starting position [lng, lat]. Note that lat must be set between -90 and 90
            zoom: 9 // starting zoom
        });
    }
    document.getElementById("detectLocation").addEventListener("click", ()=>{
        navigator.geolocation.getCurrentPosition(
            async (position) =>{
                const lat = (position.coords.latitude);
                const lng = (position.coords.longitude);
                // const accuracy = (position.coords.accuracy);
                // console.log("sending:", lat, lng);

                document.getElementById("locationStatus").style.display = "block";
                document.getElementById("locationStatus").innerText = "Fetching Address";

                const response = await fetch("/profile/address/detect",{
                    method: "POST",
                    headers: { "Content-Type": "application/json"},
                    body: JSON.stringify({lat,lng})
                })
                //  console.log("fetch status:", response.status); // ✅ check status code
                const data = await response.json();
                // console.log("data received:", data);

                if(data.success){
                    document.getElementById("city").value = data.address.city;
                    document.getElementById("state").value = data.address.state;
                    document.getElementById("pincode").value = data.address.pincode;
                    document.getElementById("street").value = data.address.street;

                    document.getElementById("locationStatus").innerText = "Location Detected!";
                }
            },
            (error)=>{ // if user clicks block for the location access
                alert("Location Access Denied. Please fill the Location Manually!");
            }
        );
    })
</script>
