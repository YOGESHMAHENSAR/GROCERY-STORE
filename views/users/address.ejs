<%- layout("/layouts/boilerplate") %>
<div class="row">
    <div class="col-md-6 offset-3 mt-4">
        <h3>Add Delivery Address</h3>
        <form action="/profile/address" method="post" class="needs-validation" novalidate>
            <div class="mb-3">
                <label class="form-label">Street Address</label>
                <input type="text" name="street" class="form-control" 
                    value="<%= currUser.address?.street || '' %>" required>
                <div class="invalid-feedback">Please enter street address</div>
            </div>
            <div class="mb-3">
                <label class="form-label">City</label>
                <input type="text" name="city" class="form-control"
                    value="<%= currUser.address?.city || '' %>" required>
                <div class="invalid-feedback">Please enter city</div>
            </div>
            <div class="mb-3">
                <label class="form-label">State</label>
                <input type="text" name="state" class="form-control"
                    value="<%= currUser.address?.state || '' %>" required>
                <div class="invalid-feedback">Please enter state</div>
            </div>
            <div class="mb-3">
                <label class="form-label">Pincode</label>
                <input type="text" name="pincode" class="form-control" 
                    pattern="[0-9]{6}" maxlength="6"
                    value="<%= currUser.address?.pincode || '' %>" required>
                <div class="invalid-feedback">Please enter valid 6-digit pincode</div>
            </div>
            <button type="submit" class="btn btn-success w-70 text-center">
                Save Address & Continue
            </button>
        </form>
    </div>
</div>