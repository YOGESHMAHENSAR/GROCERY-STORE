<% layout("/layouts/boilerplate") -%>
<body>
  <br />
  <div class="row">
    <div class="col-6 offset-3">
      <h2 class="" style="text-align: center">SignUp on GROCERY-STORE</h2>
      <br />
      <div class="login-container mt-4 mb-3">
        <div >
        <a href="/auth/google?intent=signup" class="google-btn">
            <div class="google-icon-wrapper">
                <img class="google-icon" src="https://upload.wikimedia.org/wikipedia/commons/c/c1/Google_%22G%22_logo.svg"/>
            </div>
            <span class="btn-text">Sign Up with Google</span>
        </a>

        <div class="divider mt-4 mb-3">
            <span style="margin-left: 300px;">or</span>
            <!-- <hr> -->
        </div>

        </div>
      </div>
      <!-- flash msg div start -->
      <div id="flash-msg" style="display:none;" class="col-8 offset-2 mt-2"></div>
      <!-- flash msg div ends -->
      <form action="/signup" method="post" class="needs-validation" novalidate>
        <div class="mb-3 mt-3">
          <label class="form-label" for="username">UserName </label
          ><span> <b style="color: red"> *</b> : </span>
          <input
            type="text"
            class="form-control"
            width="50%"
            id="username"
            placeholder="Enter your UserName"
            name="username"
            required
          />
          <div class="invalid-feedback">Please Enter the UserName</div>
        </div>
        <div class="mb-3">
            <div class="row">
              <div class="col-md-8">
                <label class="form-label" for="email">E-Mail Id </label
                ><span> <b style="color: red"> *</b> : </span>
                <input
                  name="email"
                  class="form-control"
                  id="email"
                  placeholder="Enter the E-Mail Id here"
                  required
                />
              </div>
              <div class="col-md-4" style="margin-top: 32px;">
                <button class="btn btn-outline-dark" type="button" id="sendotpbtn">
                  Send OTP
                </button>
                <!-- span tag for the timer in the btn itself -->
                <span id="resend-section" style="display:none;">
                  <span id="countdown" style="color:gray; font-size: 0.9rem;">
                      Resend in <b id="timer">30</b>s
                  </span>
                  <button type="button" id="resendOtpBtn" class="btn btn-sm btn-outline-warning" style="display:none;">
                      Resend OTP
                  </button>
              </span>
              </div>
            </div>
          <div class="invalid-feedback">Please provide the valid E-Mail Id</div>
        </div>
        <div class="mb-3">
          <label for="otp" class="form-label">OTP: </label>
          <span> <b style="color: red"> *</b> : </span>
          <input type="text" class="form-control" name="otp" placeholder="PLease Enter OTP here" required>
          <div class="invalid-feedback">Please Provide the OTP for Vlidation of E-Mail</div>
        </div>
        <div class="mb-3">
          <label class="form-label" for="password">Password : </label>
          <span> <b style="color: red"> *</b> : </span>
          <input
            type="password"
            class="form-control"
            width="50%"
            placeholder="Enter your password here"
            id="password"
            name="password"
            required
          />
          <div class="invalid-feedback">Please provide the password</div>
        </div>
        <br /><br />
        <button
          type="submit"
          class="btn btn-outline-success mb-5 col-6 offset-3"
        >
          Sign Up
        </button>
      </form>
      <div>
        <a href="./login?">Already have an Account!</a>
      </div>
    </div>
  </div>
</body>

<script>
    // flash message function
    function showFlash(message, type = "success") {
        const flash = document.getElementById("flash-msg");
        flash.style.position = "fixed";  // fixed to screen
        flash.style.top = "100px";        // below navbar
        flash.style.right = "10px";       // left corner
        flash.style.zIndex = "9999";     // above everything
        flash.style.width = "450px";
        flash.style.textAlign = "center";
        flash.style.fontWeight = "500";
        flash.innerHTML = `
            <div class="alert alert-${type} alert-dismissible fade show" role="alert">
                ${message}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        `;
        flash.style.display = "block";
        setTimeout(() => {
            flash.style.display = "none";
        }, 5000);
    }

    // countdown timer function
    let countdownInterval;
    function startCountdown() {
        let seconds = 30;
        const timerEl     = document.getElementById("timer");
        const countdownEl = document.getElementById("countdown");
        const mainBtn = document.getElementById("sendotpbtn");
        const resendBtn   = document.getElementById("resendOtpBtn");
        const resendSec   = document.getElementById("resend-section");

        resendSec.style.display   = "inline";
        countdownEl.style.display = "inline";
        mainBtn.style.display = "none",
        resendBtn.style.display   = "none";

        clearInterval(countdownInterval);
        countdownInterval = setInterval(() => {
            seconds--;
            timerEl.innerText = seconds;
            if (seconds <= 0) {
                clearInterval(countdownInterval);
                countdownEl.style.display = "none";
                resendBtn.style.display   = "inline";
            }
        }, 1000);// spped of the counter to decrease the 30 sec time
    }

    // main OTP sender function
    async function sendOTP() {
        const email = document.getElementById("email").value;
        const username = document.querySelector("#username").value;

        if (!username) {
            showFlash("Please enter your Username to Validate E-Mail", "danger");
            return;
        }

        if (!email) {
            showFlash("Please enter your email first!", "danger");
            return;
        }

        const response = await fetch('/getotp', {
            method: "POST",
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email })
        });

        const data = await response.json();

        if (data.success) {
            showFlash(`OTP sent successfully to your email! <br> E-Mail: <b>${email}</b> ✅`, "success");
            startCountdown(); // start 30s countdown
        } else {
            showFlash(data.message || "Failed to send OTP!", "danger");
        }
    }

    // Get OTP button
    document.getElementById("sendotpbtn").addEventListener('click', sendOTP);

    // Resend OTP button
    document.getElementById("resendOtpBtn").addEventListener('click', sendOTP);
</script>
