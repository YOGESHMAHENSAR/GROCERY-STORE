<%- layout("/layouts/boilerplate") -%>
<div style="max-width: 600px; margin: 3rem auto; text-align: center; padding: 0 1rem;">
    <% if(order) { %>  <%# ✅ guard against null %>
        <div style="background: #f0fdf4; border: 1px solid #bbf7d0; border-radius: 16px; padding: 2rem;">
            <div style="font-size: 48px; margin-bottom: 1rem;">✓</div>
            <h2 style="color: #15803d;">Order Placed Successfully!</h2>
            <p style="color: #6b7280;">Order ID: <b><%= order.orderId %></b></p>
            <p style="color: #6b7280;">Payment ID: <b><%= order.paymentId %></b></p>

            <div style="background: white; border-radius: 10px; padding: 1rem; margin: 1.5rem 0; text-align: left;">
                <h5 style="margin-bottom: 1rem;">Items Ordered</h5>
                <% for(let item of order.items) { %>
                    <div style="display: flex; justify-content: space-between; padding: 8px 0; border-bottom: 1px solid #f3f4f6;">
                        <span><%= item.product ? item.product.title : "Product" %> x<%= item.quantity %></span>
                        <span>₹<%= (item.price * item.quantity).toLocaleString("en-IN") %></span>
                    </div>
                <% } %>
                <div style="display: flex; justify-content: space-between; padding: 12px 0; font-weight: 600;">
                    <span>Total</span>
                    <span>₹<%= order.totalAmount.toLocaleString("en-IN") %></span>
                </div>
            </div>

            <div style="text-align: left; background: white; border-radius: 10px; padding: 1rem; margin-bottom: 1.5rem;">
                <h5>Delivery Address</h5>
                <p style="margin: 0; color: #6b7280;">
                    <%= order.address.street %>, <%= order.address.city %><br>
                    <%= order.address.state %> - <%= order.address.pincode %>
                </p>
            </div>

            <div style="display: flex; gap: 10px; justify-content: center;">
                <a href="/orders" class="btn btn-outline-dark">View All Orders</a>
                <a href="/listings" class="btn btn-success">Continue Shopping</a>
            </div>
        </div>
    <% } else { %>
        <p>No recent order found. <a href="/listings">Go Shopping</a></p>
    <% } %>
</div>