<%- layout("/layouts/boilerplate") -%>
<div style="max-width: 866px; margin: 1rem; padding: 0 1rem;">
    <div class="row">
        <div class="col-md-3">
            <h4 class="mb-4">Total Orders : <%= orders.length %></h3>
        </div>
        <div class="col-md-3">
            <h5 class="mb-4"><b style="color: rgb(209, 161, 17);">Pending :</b>
                <span id="count-pending">
                    <%= orders.filter(o => o.status === "Pending").length %> 
                </span> 
            </h5>
        </div>
        <div class="col-md-3">
            <h5 class="mb-4"><b style="color: rgb(82, 238, 100);">Confirmed :</b> 
                <span id="count-confirm">
                    <%= orders.filter(o => o.status === "Confirmed").length %>
                </span>
            </h5>
        </div>
        <div class="col-md-3">
            <h5 class="mb-4"><b style="color: rgb(80, 92, 225);">Delivered :</b>
                <span id="count-place">
                    <%= orders.filter(o => o.status === "Placed").length %>
                </span>  
            </h5>
        </div>
    </div>
    <% if(orders.length === 0) { %>
        <div style="text-align: center; padding: 3rem; background: #f9fafb; border-radius: 16px;">
            <p style="color: #6b7280;">NO-THING TO DELIVER YET! <br> <b><span style="color: red;">WAIT</span></b> FOR CUSTOMER TO ORDER. </p>
            <h3 style="color: #6b7280;">HAVE PATIENCE!</h3> <br>
            <a href="/listings" class="btn btn-success">GO TO HOME</a>
        </div>
    <% } else {%>

        <% 
            let totalSellingSum = orders.reduce((orderSum, order)=> {
                return orderSum + order.items.reduce((itemSum, item)=> {
                    const price = parseFloat(item.product?.sellingPrice?.toString().replace(/[^\d.-]/g, '')) || 0;
                    const taxRate = item.product && item.product.Tax ? parseFloat(item.product.Tax) / 100 : 0;
                    const priceWithTax = price * (1 + taxRate);
                    return itemSum + (priceWithTax * item.quantity);
                },0);
            },0);

            let totalCostSum = orders.reduce((orderSum, order)=>{
                return orderSum + order.items.reduce((itemSum, item)=>{
                    const price = parseFloat(item.product?.costPrice?.toString().replace(/[^\d.-]/g, '')) || 0;
                    const taxRate = item.product && item.product.Tax ? parseFloat(item.product.Tax) / 100 : 0;
                    const priceWithTax = price * (1 + taxRate);
                    return itemSum + (priceWithTax * item.quantity);
                },0)
            },0)

            let profit = totalSellingSum - totalCostSum;
        %>
        <div class="row">
            <div class="col-md-10">
                <% for(let order of orders) { %>
                    <div style="background: white; border: 1px solid #e5e7eb; border-radius: 16px; padding: 1.5rem; width: 50rem; margin-bottom: 1.5rem;">

                        <div style="display: flex; justify-content: space-between; margin-bottom: 1rem;">
                            <div>
                                <p style="margin: 0; font-size: 13px; color: #6b7280;">Customer Name</p>
                                <p style="margin: 0; font-weight: 500; font-size: 14px;"><%= order.user.username %></p>
                            </div>
                            <div>
                                <p style="margin: 0; font-size: 13px; color: #6b7280;">Contact Number</p>
                                <p style="margin: 0; font-weight: 500; font-size: 14px;"><%= order.user.phone %></p>
                            </div>
                            <div>
                                <p style="margin: 0; font-size: 13px; color: #6b7280;">Order ID</p>
                                <p style="margin: 0; font-weight: 500; font-size: 14px;"><%= order.orderId %></p>
                            </div>
                            <div>
                                <p style="margin: 0; font-size: 13px; color: #6b7280;">Ordered At </p>
                                <p style="margin: 0; font-size: 14px;">
                                    <%= order.createdAt ? new Date(order.createdAt).toLocaleDateString('en-GB') : 'N/A' %>
                                </p>
                            </div>
                            <div>
                                <!-- ✅ Status badge color based on status -->
                                <% const statusColor = {
                                    Confirmed: "#dbeafe",
                                    Pending: "#fef9c3",
                                    Delivered: "#dcfce7",
                                } %>
                                <p style="margin: 0; font-size: 13px; color: #6b7280;">Order Status </p>
                                <span data-id="<%= order.orderId %>" style="font-size: 12px; padding: 4px 12px; border-radius: 20px; background: #fef9c3;">
                                    <%= order.status %>
                                </span>
                            </div>
                            <% let sum = 0 %>
                            <% 
                                let orderSubTotal = order.items.reduce((sum, item) => sum + parseFloat(item.price) * item.quantity, 0);
                                let orderTax = order.items.reduce((sum, item) => {
                                    let itemTotal = parseFloat(item.price) * item.quantity;
                                    let taxRate = item.product && item.product.Tax ? parseFloat(item.product.Tax) / 100 : 0;
                                    return sum + (itemTotal * taxRate);
                                }, 0);
                                let orderGrandTotal = orderSubTotal + orderTax + 10;
                            %>
                            <div>
                                <p style="margin: 0; font-size: 13px; color: #6b7280;">Total</p>
                                <p style="margin: 0; font-weight: 600;">₹<%= orderGrandTotal.toFixed(2) %></p>
                            </div>
                        </div>
                        <div style="border-top: 1px solid #f3f4f6; padding-top: 1rem;">
                            <% for(let item of order.items) { %>
                                <% if(item.product) {%>
                                    <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 8px;">
                                        <img src="<%= item.product.image.url %>" 
                                            style="width: 50px; height: 50px; object-fit: cover; border-radius: 8px;" alt="">
                                        <div>
                                            <p style="margin: 0; font-size: 14px;"><%= item.product.title %></p>
                                            <p style="margin: 0; font-size: 13px; color: #6b7280;">Qty: <%= item.quantity %> × ₹<%= item.product.sellingPrice %></p>
                                        </div>
                                    </div>
                                <% } %>
                            <% } %>
                        </div>
                        <div class="row">
                            <div class="col-md-8">
                                <p class="mt-3"> <b>ADDRESS:</b> <%= order.address.street %>, <%= order.address.city %>, <%= order.address.state %>, <%= order.address.pincode %> </p>
                            </div>
                            <% if (order.status === "Pending") {%>
                                <div class="col-md-4">
                                    <button class="btn btn-outline-dark" data-category="<%= orderGrandTotal %>"
                                        data-id="<%= order.orderId %>" id="order-confirmed">
                                        <i class="fa-brands fa-whatsapp" style="color: #25D366; font-size: 1.6rem"></i> Order Confirm
                                     </button>
                                </div>
                            <% } %>
                            <% if(order.status === "Confirmed" ) {%>
                                <div class="col-md-4">
                                    <button class="btn btn-outline-success" data-category="<%= orderGrandTotal %>"
                                        data-id="<%= order.orderId %>" id="order-placed">
                                        <i class="fa-brands fa-whatsapp" style="color: #25D366; font-size: 1.6rem;"></i> Order Delivered
                                    </button>
                                </div>
                            <% } %>
                            <% if(order.status === "Placed") {%>
                                <div class="col-md-4">
                                    <h3 style="color: brown;">Order Delivered</h3>
                                </div>
                            <% } %>

                        </div>
                        
                    </div>
                <% } %>
            </div>
            <div class="col-md-2" >
                 <%# for(order of orders) {%>
                <div class="grand-total-box" style="margin-left: 18rem; position: fixed ;">
                    <div class="grand-total-row">
                        <span>Total Selling Price</span>
                        <span>₹ <%= totalSellingSum.toLocaleString("en-IN") %></span>
                    </div>
                    <div class="grand-total-row">
                        <span>Total Cost Price</span>
                        <span>₹ <%= totalCostSum.toLocaleString("en-IN") %></span>
                    </div>
                    <div class="grand-total-divider"></div>
                    <div class="grand-total-final" style="font-size: 1.2rem;">
                        Final Profit: ₹ <%= profit.toLocaleString("en-IN") %>
                    </div>
                </div>
                 <%# } %>
            </div>
        </div>
        
        
    <% } %>
</div>

<script>    
    document.addEventListener("click", async function (e){
        const orderConfirmed = e.target.closest("#order-confirmed");
        if(orderConfirmed){
            const orderId = orderConfirmed.dataset.id;
            const orderGrandTotal = orderConfirmed.dataset.category;
            await updateOrderStatus(orderId, "Confirmed", orderConfirmed, orderGrandTotal);
            return;
        }
        const orderPlaced = e.target.closest("#order-placed");
        if(orderPlaced){
            const orderId = orderPlaced.dataset.id;
            const orderGrandTotal = orderPlaced.dataset.category;
            await updateOrderStatus(orderId, "Placed", orderPlaced, orderGrandTotal);
            return;
        }
    })

    async function updateOrderStatus(orderId, status, btn, orderGrandTotal){
        console.log("Total orderId:", orderGrandTotal);

        btn.disabled = true;
        btn.innerHTML = `<i class="fa-solid fa-spinner fa-spin"></i>`;
        try{
            let response = await fetch(`/order/${orderId}/status`,{
                method: "PATCH",
                body: JSON.stringify({status, orderGrandTotal}),
                headers: {"Content-Type": "application/json"}
            })

            const data = await response.json();

            if(response.ok && data.success){
                const badge = document.querySelector(`span[data-id="${orderId}"]`);
                if(badge){
                    badge.textContent = data.status;
                    if(data.status === "Confirmed") badge.style.background = "#dbeafe";
                    else if(data.status === "Placed") badge.style.background = "#dcfce7";
                }

                btn.style.display = "none"; // hide current button
                const pendingCount = document.querySelector("#count-pending");
                const confirmCount = document.querySelector("#count-confirm");
                const placedCount = document.querySelector("#count-place");

                // ✅ inject next button based on new status
                if(data.status === "Confirmed"){
                    const div = document.createElement("div");
                    if(pendingCount) pendingCount.textContent = parseInt(pendingCount.textContent) - 1;
                    if(confirmCount) confirmCount.textContent = parseInt(confirmCount.textContent) + 1;
                    div.className = "col-md-4";
                    div.innerHTML = `
                            <button class="btn btn-outline-danger" data-id="${orderId}" id="order-placed">
                                Order Placed
                            </button>
                    `;
                    btn.parentElement.replaceWith(div); // add to same row as confirm btn
                    if (data.whatsappUrl) {
                        window.open(data.whatsappUrl, "_blank"); // ✅
                    }
                } else if(data.status === "Placed"){
                    const div = document.createElement("div");
                    if(placedCount) placedCount.textContent = parseInt(placedCount.textContent) + 1;
                    if(confirmCount) confirmCount.textContent = parseInt(confirmCount.textContent) - 1;
                    div.className = "col-md-4";
                    div.innerHTML = `<h3 style="color: brown;">Order Placed</h3>`;
                    btn.parentElement.replaceWith(div);
                    if(data.whatsappUrl){
                        window.open(data.whatsappUrl, "_blank");
                    }
                }
            }
            else {
                alert(data.message || "Failed to update order status");
                console.log(data.message);
                btn.disabled = false;
                btn.innerHTML = status === "Confirmed" ? "Order Confirm" : "Order Placed";
            }
        }catch(e){
            console.error("Error updating order status:", e);
            alert("An error occurred while updating the order status");
            btn.disabled = false;
            btn.innerHTML = status === "Confirmed" ? "Order Confirm" : "Order Placed";
        }
    }
</script>