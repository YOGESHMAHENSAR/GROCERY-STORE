<% layout("/layouts/boilerplate") -%>
<body>
    <div class="row">
        <div class="col-8 offset-2 mb-1">
            <h2 class="mt-1">Product : <b><%= lists.title %></b></h2>
        </div>
    </div>
    <div class="row">
        <div class="col-6 offset-2">
            <div class="card listing-card">
                <img src="<%= lists.image.url %>" class="card-img-top show-img" style="width: 82%;" alt="listImg">
                <div class="card-body" style="margin-top: -12px;"><br>
                    <!-- <p class="card-text"><b>Owned by: <i class="fa-solid fa-chess-king" style="color: gold;"></i> <i><%# lists.owner.username %></b></i><br> -->  
                    <p class="card-text"><b><i class="fas fa-rupee-sign"></i> : <%= lists.price?.toLocaleString("en-IN") %></b><br></p>
                        <b>Description :</b> <%= lists.description %> <br><br>
                        <% if(lists.location) {%>
                            <div class="row" style="margin-top: -10px;">
                                <div class="col-10">
                                    <b>Imported Location [Specialty]:</b> <i class="fa-solid fa-chess-king" style="color: gold;"></i> <%= lists.location %> 
                                </div>    
                            </div>
                        <% } %>
                    </p>
                </div>
            </div>
            <%# if(!lists.owners.some(o=>o._id.equals(currUser._id))) {%>
                <form action="/cart/<%= lists._id %>" method="post">
                    <button class="btn btn-outline-primary">
                        <i class="fa-solid fa-cart-shopping"></i>Add To Cart
                    </button>
                </form>
            <%# } %>
            <% if(currUser && lists.owners.some(o=>o._id.equals(currUser._id))) {%>
                <a href="/listings/<%= lists._id %>/edit"><button class="btn btn-outline-dark mb-3" style=" margin-top: -35px;">Edit</button></a>
                
                <!-- delete btn -->
                <button type="button" style="margin-left: 20px; margin-top: -35px;" class="btn btn-outline-danger mb-3" data-bs-toggle="modal" data-bs-target="#delete-<%= lists._id %>">DELETE</button>
            <% } %>
        </div>
    </div>
    <!-- model for permanently delete start -->
    <div class="modal fade" id="delete-<%= lists._id %>" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h1 class="modal-title fs-5" id="exampleModalLabel">Remove Product</h1>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p>Are you sure you want to delete this Product</b></p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">NO</button>
                    <form action="/listings/<%= lists._id %>?_method=DELETE" method="post">
                        <button class="btn btn-danger"> YES </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
    <!-- model ends -->
    <% if(currUser){ %>
        <hr>
        <div class="col-8 offset-2 mb-2 mt-3">
            <h3 class="highlighted-feedback">Feedback Section </h3>
            <form action="/listings/<%= lists._id %>/reviews" method="post" class="needs-validation" novalidate>
                <!-- <div>
                    <label for="name" class="form-label mt-3">Name</label>
                    <input type="text" pattern="[A-Za-z/s]+" name="review[name]" class="form-control" required>
                    <div class="invalid-feedback">Please provide your Name</div>
                </div> -->
                <div>
                    <!-- <h5>Rating</h5> -->
                    <label for="rating" class="form-label mt-3">Rating</label>
                    <input type="range" min="1" max="5" name="review[rating]" id="rating" value="4" class="form-range">
                    <output for="rating" id="rangeValue" class="highlighted-output" aria-hidden="true"></output>
                </div>
                <br>
                <div>
                    <!-- <h5>Comments</h5> -->
                    <label for="comment" class="form-label mt-2">Comment <span style="color: red;">*</span> </label>
                    <textarea name="review[comment]" id="comment" maxlength="400" class="form-control" title="Provide your valuable Feedback in range of 400 words" placeholder="Please Provide your valuable Feedback in 400 words" cols="30" rows="7" required></textarea>
                    <div class="invalid-feedback">Please provide the feedback</div>
                </div>
                <button class="btn btn-outline-dark mt-3">Subimt Response</button>
            </form>
        </div>
    <% } %>
    <hr> 
    <div class="col-8 offset-2 mb-2 mt-2" style="margin-top: -10px;">
        <h3>Feedbacks : </h3>
        <% if(lists.reviews.length === 0){ %>
            <div class="d-flex justify-content-center">
                <!-- <h3 class="mb-4">no review yet!</h3> <br> -->
                <img src="../css/imageReview.png" class="mt-3" style="height: 403px; width: 562px;" alt="no review yet pic">
            </div>
        <% } %>
        <div class="row mt-2">
            <% for(review of lists.reviews){ %>
                <div class="card col-md-6 ms-2 mt-3" style="width: 26rem; padding: .5rem; margin-left: 20px;">
                    <div class="row">
                        <div class="col-md-3">
                            <img src="../css/demo_user.png" class="card-img-top demo_user" style="border-radius: 50%; height: 63px; width: 63px;" alt="...">
                        </div>
                        <div class="col-md-8">
                            <h6 class="mt-2" style="margin-left: -20px;"><b><%= review.author.username %></b></h6>
                            <h6 style="margin-left: -20px;">1 years on GROCERY-STORE</h6>
                        </div>
                    </div>
                    <hr>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6">
                                <p>Rating: <%= review.rating %><i class="fa-solid fa-star" style="color: rgb(255, 196, 0);"></i></p>
                            </div>
                            <div class="col-md-6">
                                <p style="font-size: 1rem; margin-left: -100px;"><%= review.createdAt.toLocaleDateString('en-UK') %></p>
                            </div>
                        </div>                        
                        <p class="card-text"><%= review.comment %></p>
                    </div>
                    <!-- <form action="/listings/<%# lists._id %>/reviews/<%# review._id %>?_method=DELETE" method="POST">
                        <button class="btn btn-danger mt-2 ">Delete</button>
                    </form> -->
                    
                    <% if(currUser && currUser._id.equals(review.author._id)) { %>
                        <button type="button" style="width: 95px;" class="btn btn-sm btn-danger mt-2" data-bs-toggle="modal" data-bs-target="#delete-review-<%= review._id %>">DELETE</button>
                        <!-- model for permanently delete start -->
                        <div class="modal fade" id="delete-review-<%= review._id %>" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
                            <div class="modal-dialog">
                                <div class="modal-content">
                                    <div class="modal-header">
                                        <h1 class="modal-title fs-5" id="exampleModalLabel">REMOVE Review</h1>
                                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                    </div>
                                    <div class="modal-body">
                                        <p>Are you sure you want to Remove your Review</b></p>
                                    </div>
                                    <div class="modal-footer">
                                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">NO</button>
                                        <form action="/listings/<%= lists._id %>/reviews/<%= review._id %>?_method=DELETE" method="post">
                                            <button class="btn btn-danger">YES </button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <!-- model ends -->
                    <% } %>
                </div>
                
            <% } %>
        </div>
    </div>    
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>