<% layout("/layouts/boilerplate") -%>
<body>
    <div class="row">
        <div class="col-8 offset-2 mb-1">
            <h2 class="mt-1">Product : <b><%= lists.title %></b></h2>
        </div>
    </div>
    <div class="row">
        <div class="col-6 offset-2" style="width: 82%;">
            <div class="card listing-card" style="border-radius: 15px; padding: 2px;">
                <div class="row">
                    <div class="col-md-6">
                        <img src="<%= lists.image.url %>" class="card-img-top show-img" alt="listImg">
                    </div>
                    <div class="col-md-6" >
                        <div class="card-body" style="margin-top: -12px;"><br>
                            <!-- <p class="card-text"><b>Owned by: <i class="fa-solid fa-chess-king" style="color: gold;"></i> <i><%# lists.owner.username %></b></i><br> -->  
                            <p class="card-text mt-3"><b><i class="fas fa-rupee-sign"></i> : <%= lists.sellingPrice?.toLocaleString("en-IN") %></b><br></p>
                                <% if(currUser && lists.owners.some(o=>o._id.equals(currUser._id))) {%>
                                    <div class="row">
                                        <div class="col-md-4">
                                            <b>Cost-Price: </b> <%= lists.costPrice %> 
                                        </div>
                                        <div class="col-md-4">
                                            <b>Profit Margin : </b> <%= lists.margin %>%
                                        </div>
                                        <div class="col-md-4">
                                            <b>Tax: </b> <%= lists.Tax %>%
                                        </div>
                                        <%# lists.sellingPrice = (lists.costPrice * (1+ lists.margin)) * (1+ lists.Tax) %>
                                        <div class="col-md-4">
                                            <b>Selling-Price: </b> <%= lists.sellingPrice %>
                                        </div>
                                    </div>
                                    <br>
                                <% } %>
                                
                                <b>Description :</b> <%= lists.description %> <br><br>
                                <b>Category :</b> <%= lists.category %> <br><br>
                                <% if(lists.location) {%>
                                    <div class="row" style="margin-top: -10px;">
                                        <div class="col-10">
                                            <b>Special Feature [USP] : </b> <i class="fa-solid fa-chess-king" style="color: gold;"></i> <%= lists.location %> 
                                        </div>    
                                    </div>
                                <% } %>
                                <br>
                                <br>
                                <% if(!currUser || !lists.owners.some(o=>o._id.equals(currUser._id))) {%>
                                    <div class="row mt-3">
                                        <div class="col-md-6">
                                            <% const alreadyAdded = addedToCart && addedToCart.includes(lists._id.toString()) %>
                                            <% if(alreadyAdded) {%>
                                                <a href="/cart" class="btn btn-outline-success">
                                                    <i class="fa-solid fa-cart-shopping"></i>View Cart
                                                </a>
                                            <% } else { %>
                                            <form action="/cart/<%= lists._id %>" method="post" id="cart-form">
                                                <input type="hidden" name="returnTo" value="/listings/<%= lists._id %>">
                                                <button class="btn btn-outline-primary" style="margin-top: -50px;">
                                                    <i class="fa-solid fa-cart-shopping"></i>Add To Cart
                                                </button>
                                            </form>
                                            <div class="loader-overlay" id="cartLoaderOverlay">
                                                <div class="loader-container">
                                                    <div class="loader"></div>
                                                    <p class="loader-text">Adding to Cart ... </p>
                                                </div>
                                            </div>
                                            <% } %>
                                        </div>
                                        <!-- <div class="col-md-6">
                                            <form action="/cart/<%# cart.product._id %>?_method=PUT" method="POST">
                                                <input type="hidden" value="plus" name="action">
                                                <button id="plus" class="btn btn-outline-primary"><i class="fa-solid fa-square-plus" style="font-size: 1.3rem; margin-left: 25px;"></i></button> 
                                            </form>
                                            <form action="/cart/<%# cart.product._id %>?_method=PUT" method="POST">
                                                <input type="hidden" name="action" value="minus">
                                                <button id="minus" class="btn btn-outline-danger"><i class="fa-solid fa-square-minus" style="font-size: 1.3rem; margin-left: 5px;"></i></button> 
                                            </form>
                                        </div> -->
                                    </div>
                                <% } %>
                            </p>
                        </div>
                    </div>
                </div>
            </div>
            <% if(currUser && lists.owners.some(o=>o._id.equals(currUser._id))) {%>
                <h6 style="margin-left: 259px;">As owner, cart option <b style="color: red;">not available!</b></h6>
                <a href="/listings/<%= lists._id %>/edit"><button class="btn btn-outline-dark mb-3" style=" margin-top: -35px;">Edit</button></a>
                
                <!-- delete btn -->
                <button type="button" style="margin-left: 20px; margin-top: -35px;" class="btn btn-outline-danger mb-3" data-bs-toggle="modal" data-bs-target="#delete-<%= lists._id %>">DELETE</button>
            <% } %>
        </div>
    </div>
    <!-- model for permanently delete start -->
    <div class="modal fade" id="delete-<%= lists._id %>" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h1 class="modal-title fs-5" id="exampleModalLabel">Remove Product</h1>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p>Are you sure you want to delete this Product</b></p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">NO</button>
                    <form action="/listings/<%= lists._id %>?_method=DELETE" method="post">
                        <button class="btn btn-danger"> YES </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
    <!-- model ends -->
    <% if(currUser){ %>
        <hr>
        <div class="col-8 offset-2 mb-2 mt-3">
            <h3 class="highlighted-feedback">Feedback Section </h3>
            <form action="/listings/<%= lists._id %>/reviews" method="post" class="needs-validation" novalidate>
                <!-- <div>
                    <label for="name" class="form-label mt-3">Name</label>
                    <input type="text" pattern="[A-Za-z/s]+" name="review[name]" class="form-control" required>
                    <div class="invalid-feedback">Please provide your Name</div>
                </div> -->
                <div>
                    <!-- <h5>Rating</h5> -->
                    <fieldset class="starability-heart">
                        <legend>Rating : <span style="color: red;">*</span> </legend>
                        <!-- <label for="rating" class="form-label mt-3">Rating</label> -->
                        <!-- <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="0" checked aria-label="No rating." /> -->
                        <input type="radio" id="first-rate1" name="review[rating]" value="1" required/>
                        <label for="first-rate1" tooltip="Terrible">1 star</label>
                        <input type="radio" id="first-rate2" name="review[rating]" value="2" required/>
                        <label for="first-rate2" title="Not good">2 stars</label>
                        <input type="radio" id="first-rate3" name="review[rating]" value="3" required/>
                        <label for="first-rate3" title="Average">3 stars</label>
                        <input type="radio" id="first-rate4" name="review[rating]" value="4" required/>
                        <label for="first-rate4" title="Very good">4 stars</label>
                        <input type="radio" id="first-rate5" name="review[rating]" value="5" required/>
                        <label for="first-rate5" title="Amazing">5 stars</label>
                    </fieldset>
                    <div class="invalid-feedback">Please Provide rating to Submit Response</div>
                </div>
                <br>
                <div>
                    <!-- <h5>Comments</h5> -->
                    <label for="comment" class="form-label mt-2">Comment : </label>
                    <textarea name="review[comment]" id="comment" maxlength="400" class="form-control" title="Provide your valuable Feedback in range of 400 words" placeholder="Please Provide your valuable Feedback in 400 words (Optional)" cols="30" rows="7" ></textarea>
                    <div class="invalid-feedback">Please provide the feedback</div>
                </div>
                <button class="btn btn-outline-dark mt-3">Subimt Response</button>
            </form>
        </div>
    <% } %>
    <hr> 
    <div class="col-8 offset-2 mb-2 mt-2" style="margin-top: -10px;">
        <h3>Feedbacks : </h3>
        <% if(lists.reviews.length === 0){ %>
            <div class="d-flex justify-content-center">
                <!-- <h3 class="mb-4">no review yet!</h3> <br> -->
                <img src="../css/imageReview.png" class="mt-3" style="height: 403px; width: 562px;" alt="no review yet pic">
            </div>
        <% } %>
        <div class="row mt-2">
            <% for(review of lists.reviews){ %>
                <div class="card col-md-6 ms-4 mt-3" style="width: 26rem; padding: .5rem; margin-left: 30px;">
                    <div class="row">
                        <div class="col-md-3">
                            <img src="../css/demo_user.png" class="card-img-top demo_user" style="border-radius: 50%; height: 63px; width: 63px;" alt="...">
                        </div>
                        <div class="col-md-8">
                            <h6 class="mt-2" style="margin-left: -20px;"><b><%= review.author.username %></b></h6>
                            <!-- <h6 style="margin-left: -20px;"><%# (currUser.createdAt - Date.now())  %> on GROCERY-STORE</h6> -->
                            <h6 style="margin-left: -20px;">Joined 
                                <%
                                    const diff = Date.now() - new Date(review.createdAt);
                                    const days = Math.floor(diff / (1000 * 60 * 60 * 24));
                                    
                                    let display;
                                    if(days === 0)       display = "Today";
                                    else if(days === 1)  display = "Yesterday";
                                    else if(days < 30)   display = `${days} days ago`;
                                    else if(days < 365)  display = `${Math.floor(days / 30)} months ago`;
                                    else                 display = `${Math.floor(days / 365)} years ago`;
                                %>
                                <%= display %> on <br>GROCERY-STORE
                            </h6>
                        </div>
                    </div>
                    <hr>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6">
                                <!-- <p>Rating: <%# review.rating %><i class="fa-solid fa-star" style="color: rgb(255, 196, 0);"></i></p> -->
                                <p class="starability-result" data-rating="<%= review.rating %>"></p>
                            </div>
                            <div class="col-md-6">
                                <h6>Created at: </h6>
                                <p style="font-size: 1rem; margin-left: 00px;"><%= review.createdAt.toLocaleDateString('en-UK') %></p>
                            </div>
                        </div>                        
                        <p class="card-text"><%= review.comment %></p>
                    </div>
                    <!-- <form action="/listings/<%# lists._id %>/reviews/<%# review._id %>?_method=DELETE" method="POST">
                        <button class="btn btn-danger mt-2 ">Delete</button>
                    </form> -->
                    
                    <% if(currUser && currUser._id.equals(review.author._id)) { %>
                        <div class="row">
                            <div class="col-md-6">
                                <button type="button" style="width: 100px;" class="btn btn-sm btn-outline-danger mt-2" data-bs-toggle="modal" data-bs-target="#delete-review-<%= review._id %>"><i class="fa-solid fa-trash" style="margin-right: 5px;"></i>DELETE</button>
                                <!-- model for permanently delete start -->
                                <div class="modal fade" id="delete-review-<%= review._id %>" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
                                    <div class="modal-dialog">
                                        <div class="modal-content">
                                            <div class="modal-header">
                                                <h1 class="modal-title fs-5" id="exampleModalLabel">REMOVE Review</h1>
                                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                            </div>
                                            <div class="modal-body">
                                                <p>Are you sure you want to Remove your Review</b></p>
                                                <b>Review: </b> <p><%= review.comment %></p>
                                            </div>
                                            <div class="modal-footer">
                                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">NO</button>
                                                <form action="/listings/<%= lists._id %>/reviews/<%= review._id %>?_method=DELETE" method="post">
                                                    <button class="btn btn-danger">YES </button>
                                                </form>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <!-- model ends -->
                            </div>
                            <div class="col-md-6">
                                <button type="button" style="width: 95px;" class="btn btn-sm btn-outline-primary mt-2" data-bs-toggle="modal" data-bs-target="#edit-review-<%= review._id %>">EDIT</button>
                                <!-- model for permanently delete start -->
                                <div class="modal fade" id="edit-review-<%= review._id %>" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
                                    <div class="modal-dialog">
                                        <div class="modal-content">
                                            <div class="modal-header">
                                                <h1 class="modal-title fs-5" id="exampleModalLabel">EDIT Review</h1>
                                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                            </div>
                                            <!-- modal body begins -->
                                            <form action="/listings/<%= lists._id %>/reviews/<%= review._id %>?_method=PUT" method="post">
                                                <div class="modal-body">
                                                    <div>
                                                        <!-- <h5>Rating</h5> -->
                                                        <fieldset class="starability-heart">
                                                            <legend>Rating : </legend>
                                                            <input type="radio" id="edit-rate1-<%= review._id %>" name="review[rating]" value="1" <%= (review.rating == '1' ? 'checked' : '') %> />
                                                            <label for="edit-rate1-<%= review._id %>" tooltip="Terrible">1 star</label>
                                                            <input type="radio" id="edit-rate2-<%= review._id %>" name="review[rating]" value="2" <%= (review.rating == '2' ? 'checked' : '') %> />
                                                            <label for="edit-rate2-<%= review._id %>" title="Not good">2 stars</label>
                                                            <input type="radio" id="edit-rate3-<%= review._id %>" name="review[rating]" value="3" <%= (review.rating == '3' ? 'checked' : '') %> />
                                                            <label for="edit-rate3-<%= review._id %>" title="Average">3 stars</label>
                                                            <input type="radio" id="edit-rate4-<%= review._id %>" name="review[rating]" value="4" <%= (review.rating == '4' ? 'checked' : '') %> />
                                                            <label for="edit-rate4-<%= review._id %>" title="Very good">4 stars</label>
                                                            <input type="radio" id="edit-rate5-<%= review._id %>" name="review[rating]" value="5" <%= (review.rating == '5' ? 'checked' : '') %> />
                                                            <label for="edit-rate5-<%= review._id %>" title="Amazing">5 stars</label>
                                                        </fieldset>
                                                    </div>
                                                    <br>
                                                    <div>
                                                        <!-- <h5>Comments</h5> -->
                                                        <label for="comment" class="form-label mt-2">Comment </label>
                                                        <textarea name="review[comment]" id="comment" maxlength="400" class="form-control" title="Provide your valuable Feedback in range of 400 words" placeholder="Please Provide your valuable Feedback in 400 words (Optional)" cols="30" rows="7" ><%= review.comment %></textarea>
                                                        <div class="invalid-feedback">Please provide the feedback</div>
                                                    </div>
                                                </div>
                                                <div class="modal-footer">
                                                    <button type="submit" class="btn btn-secondary" data-bs-dismiss="modal">BACK</button>
                                                    <button class="btn btn-outline-success">UPDATE </button>
                                                </div>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                                <!-- model ends -->
                            </div>
                        </div>
                    <% } %>
                </div>
            <% } %>
        </div>
    </div>    
    <!-- <script>
        document.getElementById("add-to-cart").addEventListener("click", function (e){
            const btn = e.currentTarget;
            btn.disabled = true;
            btn.innerHTML = `<i class="fa-solid fa-spinner fa-spin"></i>`;
        })
            no use for this as this require the fetch to stop the rotating but we are using the form so we remove it 
    </script>  -->
    <script>
        document.getElementById("cart-form").addEventListener("submit", function() {
            document.getElementById("cartLoaderOverlay").style.display = "flex";
        });
    </script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>