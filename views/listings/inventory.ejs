<% layout("/layouts/boilerplate") %>

<div class="container ">
    <style>
        .stock-status {
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 13px;
            font-weight: 600;
            display: inline-block;
        }
        .stock-status.in-stock {
            background: #dcfce7;
            color: green;
        }
        .stock-status.out-stock {
            background: #fee2e2;
            color: red;
        }
    </style>
    <div class="row">
        <div class="col-md-5">
            <h3 class="mt-3">Product listed :</h3>
        </div>
        <div class="col-md-4 mt-4">
            <label for="search" class="form-label"><b>Search: </b></label>
            <input type="text" id="search" class="form-control" style="margin-top: -38px; margin-left: 72px;" placeholder="Search By Name, Category, Price, Stock" width="100px">
        </div>
    </div>
    <div class="row mt-4 mb-4">
        <div class="col-md-3">
            <div style="background: #f0fdf4; border-radius: 15px; padding: 1rem;">
                <h5 style="color: green;">Total Products: </h5>
                <h3 ><%= lists.length %></h3>
            </div>
        </div>
        <div class="col-md-3">
            <div style="background: #f0fdf4; border-radius: 15px; padding: 1rem;">
                <h5 style="color: green;">Product InStock: </h5>
                <h3 class="count-instock"><%= lists.filter(l => l.inStock).length %></h3>
            </div>
        </div>
        <div class="col-md-3">
            <div style="background: #f0fdf4; border-radius: 15px; padding: 1rem;">
                <h5 style="color: red;">Product OutOf Stock: </h5>
                <h3 class="count-outofstock"><%= lists.filter(l => !l.inStock).length %></h3>
            </div>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-bordered table-hover align-middle">
            <thead class="table-dark">

                <tr>
                    <th>#</th>
                    <th>Image</th>
                    <th>Title</th>
                    <th>Category</th>
                    <th>Cost Price</th>
                    <th>Selling Price</th>
                    <th>Margin %</th>
                    <th>Tax %</th>
                    <th>In Stock</th>
                    <th>Action</th>
                    <th>Toggle</th>
                    <th>Discount</th>
                </tr>
            </thead>
            <tbody>
                <% for(let i=0 ;i<lists.length; i++) {%>
                    <% let list = lists[i]; %>
                    <tr>
                        <td>
                            <%= i+1 %>
                        </td>
                        <td>
                            <img src="<%= list.image.url %>?w=80&h=80&c=fill&q=auto"
                                style="width: 60px; height: 60px; object-fit: cover; border-radius: 10px;" 
                                alt="<%= list.title %>">
                        </td>
                        <td>
                            <%= list.title %>
                        </td>
                        <td>
                            <% let cat = list.category %>
                            <% if(cat == "Normal") {%>
                                Grocery
                            <% }else{ %>
                                <%= cat %>
                            <% } %>
                        </td>
                        <td>
                            <%= list.costPrice %>
                        </td>
                        <td>
                            <%= list.sellingPrice %>
                        </td>
                        <td>
                            <%= list.margin %> %
                        </td>
                        <td>
                            <%= list.Tax %> %
                        </td>
                        <td>
                            <span id="status-<%= list._id %>" class="stock-status <%= list.inStock ? 'in-stock' : 'out-stock' %>">
                                <%= list.inStock ? "✅ In Stock" : "❌ Out of Stock" %>
                            </span>
                        </td>
                        <td>
                            <input type="checkbox" 
                            data-id="<%= list._id %>"
                            class="form-check-input stock-toggle"
                            style="cursor: pointer; width: 1.2rem; height: 1.2rem" 
                            <%= list.inStock?"checked":"" %> >
                        </td>
                        <td>
                            <a href="/listings/<%= list._id %>" class="btn btn-sm btn-outline-primary me-1">
                                <i class="fa-solid fa-eye"></i>
                            </a>
                            <a href="/listings/<%= list._id %>/edit" class="btn btn-sm btn-outline-warning me-1">
                                <i class="fa-solid fa-pen"></i>
                            </a>
                            <a href="/listings/<%= list._id %>" class="btn btn-sm btn-outline-danger me-1">
                                <i class="fa-solid fa-trash"></i>
                            </a>
                        </td>
                        <td>
                            <h6>NO</h6>
                        </td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>

<script>
    document.addEventListener("change",async (e)=>{
        const toggle = e.target.closest(".stock-toggle");
        if(!toggle) return;

        const id = toggle.dataset.id;
        const inStock = toggle.checked;

        try{
            const response = await fetch(`/listings/inventory/${id}/stock`,{
                method: "PATCH",
                headers: { "Content-Type": "application/json"},
                body: JSON.stringify({ inStock })
            })

            const data = await response.json();

            if(response.ok && data.success){
                const badge = document.getElementById(`status-${id}`);
                if(badge){
                    badge.textContent = data.inStock ? "✅ In Stock" : "❌ Out of Stock";
                    badge.className = `stock-status ${data.inStock ? 'in-stock' : 'out-stock'}`;
                }

                const inStockCount = document.getElementsByClassName("count-instock")[0];
                const outofStockCount = document.getElementsByClassName("count-outofstock")[0];

                if(data.inStock){
                    inStockCount.textContent = parseInt(inStockCount.textContent) + 1;
                    outofStockCount.textContent = parseInt(outofStockCount.textContent) - 1;
                }else{
                    inStockCount.textContent = parseInt(inStockCount.textContent) - 1;
                    outofStockCount.textContent = parseInt(outofStockCount.textContent) + 1;
                }
            } 
            else {
                toggle.checked = !toggle.checked; // ✅ revert if failed
                alert("Failed to update stock status");
            }
        }
        catch(err) {
            console.error(err);
            toggle.checked = !toggle.checked; // ✅ revert on error
            alert("Something went wrong");
        }
    })
    document.getElementById("search").addEventListener("input", function() {
        const searchValue = this.value.toLowerCase().trim();
        const rows = document.querySelectorAll("tbody tr");

        rows.forEach(row => {
            const title    = row.querySelector("td:nth-child(3)")?.textContent.toLowerCase() || "";
            const category = row.querySelector("td:nth-child(4)")?.textContent.toLowerCase() || "";
            const price    = row.querySelector("td:nth-child(6)")?.textContent.toLowerCase() || "";
            const stock    = row.querySelector("td:nth-child(9)")?.textContent.toLowerCase() || "";

            if(title.includes(searchValue) || category.includes(searchValue) || price.includes(searchValue) || stock.includes(searchValue)) {
                row.style.display = "";      // ✅ show row
            } else {
                row.style.display = "none";  // ✅ hide row
            }
        });
    });
</script>