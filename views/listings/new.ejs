<% layout("/layouts/boilerplate") -%>
<body>
  <br />
  <div class="row">
    <div class="col-8 offset-2">
      <h2>Add New Product</h2>
      <br />
      <form
        action="/listings"
        method="POST"
        class="needs-validation"
        enctype="multipart/form-data"
        novalidate
      >
        <div class="mb-3">
          <label class="form-label" for="title">Name of Product </label
          ><span> <b style="color: red"> *</b> : </span>
          <input
            type="text"
            class="form-control"
            width="50%"
            id="title"
            placeholder="Enter Name Of Product"
            name="listing[title]"
            required
          />
          <div class="invalid-feedback">Please Enter a valid Name</div>
        </div>
        <div class="mb-3">
          <label class="form-label" for="desc">Description </label
          ><span> <b style="color: red"> *</b> : </span>
          <textarea
            name="listing[description]"
            class="form-control"
            id="desc"
            rows="5"
            cols="30"
            placeholder="Enter the description of the Product"
            required
          ></textarea>
          <div class="invalid-feedback">
            Please provide the valid Description
          </div>
        </div>
        <div class="mb-3">
          <label class="form-label" for="img">Upload Image of Product</label
          ><span> <b style="color: red"> *</b> : </span>
          <input
            type="file"
            class="form-control"
            width="50%"
            accept="image/jpeg, image/png, image/jpg"
            placeholder="Browse Image to Upload"
            width="500px"
            id="img"
            name="listing[image]"
            required
          />
          <div class="invalid-feedback">
            Please Select image of type: jpeg, png only
          </div>
        </div>
        <div class="row">
          <div class="mb-3 col-md-4">
            <label class="form-label" for="price">Select Category </label
            ><span> <b style="color: red"> *</b> : </span>
            <select
              class="form-select"
              name="listing[category]"
              id="category"
              onchange="setTax(this.value)"
            >
              <option value="" selected disabled>Select Category</option>
              <option value="Beverages">Beverages (12% Tax)</option>
              <option value="Snacks">Snacks and Sweets (18% Tax)</option>
              <option value="Dairy">Dairy & Eggs (2% Tax)</option>
              <option value="Grocery">Grocery (5% Tax)</option>
            </select>
            <div class="invalid-feedback">Please Provide the valid Price</div>
          </div>
        </div>
        <div class="divider mt-4 mb-3">
          <span
            style="
              margin-left: 330px;
              color: rgb(137, 132, 132);
              font-weight: 700;
              font-size: 20px;
            "
            ><u>Cost Section</u></span
          >
          <!-- <hr> -->
        </div>
        <br />
        <div class="row">
          <div class="mb-3 col-md-4">
            <label class="form-label" for="price">Cost Price </label
            ><span> <b style="color: red"> *</b> : </span>
            <input
              type="number"
              min="0"
              class="form-control"
              width="50%"
              placeholder="Enter Cost price of Product"
              id="costPrice"
              name="listing[costPrice]"
              oninput="if (this.value < 0) this.value = 0;"
              required
            />
            <div class="invalid-feedback">
              Please Provide the valid Cost Price
            </div>
          </div>
          <div class="mb-3 col-md-4">
            <label class="form-label" for="price">Tax on Product %: </label
            ><span> <b style="color: red"> *</b> : </span>
            <input
              type="number"
              min="0"
              class="form-control"
              width="50%"
              placeholder="Select Category for Tax"
              id="taxField"
              name="listing[Tax]"
              oninput="if (this.value < 0) this.value = 0;"
              required
              readonly
            />
            <div class="invalid-feedback">
              Please Select valid Category for Tax Selection
            </div>
          </div>
          <div class="mb-3 col-md-4">
            <label class="form-label" for="price"
              >Profit Margin %: </label
            ><span> <b style="color: red"> *</b> : </span>
            <input
              type="number"
              min="0"
              class="form-control"
              width="50%"
              placeholder="Enter Margin Percentage"
              id="margin"
              name="listing[margin]"
              oninput="if (this.value < 0) this.value = 0;"
              required
            />
            <div class="mt-2" style="font-size: 13px;">Profit Margin is Considered in <b>Percentage</b><span style="color: red;">*</span></div>
            <div class="invalid-feedback">
              Please Provide the valid Profit Margin
            </div>
          </div>
        </div>
        <div class="mb-3">
          <label class="form-label" for="loc"
            >Special Feature [USP] :
            <i class="fa-solid fa-chess-king" style="color: gold"></i
          ></label>
          <!-- <span> <b style="color: red"> *</b> : </span> -->
          <input
            type="text"
            class="form-control"
            width="50%"
            placeholder="Enter the USP of Product (Optional)"
            id="loc"
            name="listing[location]"
            value=""
          />
          <div class="invalid-feedback">
            Please provide the Valid Imported Location
          </div>
        </div>
        <div class="new-btn">
          <button class="btn btn-outline-dark mb-3 mt-3">Add Product</button>
        </div>
        <br /><br />
      </form>
    </div>
  </div>
  <div class="loader-overlay" id="loaderOverlay">
    <div class="loader-container">
      <div class="loader"></div>
      <p class="loader-text">Adding New Product ...</p>
    </div>
  </div>
</body>
<script>
  const form = document.querySelector(".needs-validation");

  form.addEventListener("submit", (e) => {
    if (!form.checkValidity()) {
      e.preventDefault();
      e.stopPropagation();
      form.classList.add("was-validated");
      return; // ← don't show loader if form is invalid
    }
    // form is valid — show loader
    document.getElementById("loaderOverlay").classList.add("active");
  });
</script>
