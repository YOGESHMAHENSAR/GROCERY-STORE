<%- layout("/layouts/boilerplate") %>
<head>
  <link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,100..900;1,100..900&family=Newsreader:ital,opsz,wght@0,6..72,200..800;1,6..72,200..800&family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=Plus+Jakarta+Sans:ital,wght@0,200..800;1,200..800&display=swap" rel="stylesheet">
</head>
<body>
  <!-- <h2 class="mb-4 heading">AVAILABLE PRODUCTS : </h2> -->
   <div class="continer-fluid mt-2 mb-3 text-center">
    <span class="d-inline-block rotating-text">
      Invest in your <b>HEALTH </b> Order <b>NOW!</b>
    </span>
   </div>
  <form action="/listings/new" method="get">
    <!-- <button>ADD Listings</button> -->
  </form>

  <div class="row row-cols-lg-6 row-cols-md-2 row-cols-sm-1 row-cols-xs-1">
    <% for(let list of lists) {%>
        <!-- <a href="/listings/<%# list._id %>" class=""> -->
            <div class="card listing-card listing-link" 
            style="border-radius: 17px; width: 13rem; height: 18rem; margin-left: .5rem; cursor: pointer;" 
            onclick="window.location='/listings/<%= list._id %>'">
                <!-- <img src="<%# list.image.url %>" class="card-img-top main_img" style="height: 20rem" alt="..." /> -->
                 <img 
                  src="<%= list.image.url %>?w=600&h=400&c=fill&q=auto&f=auto" 
                  srcset="
                    <%= list.image.url %>?w=300&q=auto&f=auto 300w,
                    <%= list.image.url %>?w=600&q=auto&f=auto 600w,
                    <%= list.image.url %>?w=1200&q=auto&f=auto 1200w
                  "
                  sizes="(max-width: 600px) 200px, (max-width: 1200px) 600px, 1200px"
                  loading="lazy"
                  class="card-img-top main_img" style="height: 10rem; padding: 2px;" alt="..." />
                <!-- <div class="card-img-overlay" ></div> -->
                <div class="card-body ms-2" >
                    <p class="card-text">
                      <b ><%= list.title %></b> <br />
                      <div class="row">
                        <div class="col-md-12" style="margin-top: -10px;">
                          <i class="fas fa-rupee-sign"></i><b> : <%=list.sellingPrice?.toLocaleString("en-IN") %> </b>
                        </div>
                      </div>
                      <% if(!currUser || !list.owners.some(o=>o._id.equals(currUser._id))) {%>
                          <div class="row mt-3">
                            <% const alreadyAdded = addedToCart && addedToCart.includes(list._id.toString()); %>
                            <% if(alreadyAdded) {%>
                              <a href="/cart" class="btn btn-outline-success" style="margin-top: -9px;margin: auto;width: 9rem;" onclick="event.stopPropagation()">
                                <i class="fa-solid fa-cart-shopping"></i> View Cart
                              </a>
                            <% } else { %>
                              <!-- <form action="/cart/<%# list._id %>" method="post" onsubmit="showLoader(this)"> -->
                                  <input type="hidden" name="returnTo" value="/listings?category=<%= category %>">
                                  <button type="button" data-id="<%= list._id %>" data-category="<%= category %>" 
                                    class="btn btn-outline-primary add-to-cart-btn" title="Add To Cart"
                                    style="margin-top: -13px;margin-left: 115px;width: 4rem;"
                                    onclick="addToCart(event, '<%= list._id %>', '<%= category %>')">
                                      <i class="fa-solid fa-cart-shopping"></i>
                                  </button>
                              <!-- </form> -->
                            <% } %>
                               <!-- <div style="margin-left: 130px; font-size: 14px;margin-top: -20px;">CART<span style="color: red; "><b>*</b></span></div> -->
                          </div>
                      <% } %>
                      <!-- Review show in front only betterment of the UI/UX -->
                      <!-- <div class="col-md-6">
                        Rating: <b> : <%#list.reviews.rating %> </b>
                      </div> -->
                      
                    </p>
                </div>
            </div>
        <!-- </a> -->
    <% } %>
  </div>
  <!-- <script>
    function showLoader(event){
      const btn = event.querySelector(".btn");
      btn.disabled = true;
      btn.innerHTML = `<i class="fa-solid fa-spinner fa-spin"></i>`;
    }
  </script> -->
  <script>
    async function addToCart(event, id, category) {
      event.stopPropagation();
      const btn = event.target.closest(".add-to-cart-btn");

      const url = `/cart/${id}/fetch`;
      btn.disabled = true;
      btn.innerHTML = `<i class="fa-solid fa-spinner fa-spin"></i>`;

      try {
        const response = await fetch(url, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ returnTo: `/listings?category=${category}` })
        });

        const data = await response.json();

        if (response.ok) {
          const a = document.createElement("a");
          a.href = "/cart";
          a.className = "btn btn-outline-success";
          a.innerHTML = `<i class="fa-solid fa-cart-shopping"></i>View Cart`;
          a.style.width = "9rem";
          a.style.margin = "auto";
          a.style.marginTop = "-9px";
          a.onclick = (e) => e.stopPropagation(); // Block card click
          btn.replaceWith(a);

          const badge = document.getElementById("cart-count");
          if (badge) badge.textContent = data.cartCount;
        } else {
          alert(data.error || "Failed to add item to cart");
          btn.disabled = false;
          btn.innerHTML = `<i class="fa-solid fa-cart-shopping"></i>`;
        }
      } catch (err) {
        btn.disabled = false;
        btn.innerHTML = `<i class="fa-solid fa-cart-shopping"></i>`;
      }
    }
  </script>
</body>
